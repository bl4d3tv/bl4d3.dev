---
import "~/styles/global.css";
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import CommonHead from "~/components/common-head.astro";
import { Font } from "astro:assets";

interface Props {
  title: string;
  locale?: string;
}

const { title, locale = "en" } = Astro.props;
---

<html lang={locale}>
  <head>
    <Font cssVariable="--font-uncut-sans" preload />
    <CommonHead {title} />
    <title>{title}</title>
  </head>
  <body>
    <Header {locale} />
    <slot />
    <Footer {locale} />
  </body>
</html>
