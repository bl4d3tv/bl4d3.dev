---
interface Props {
  name: string;
  description: string;
  link: string;
}

const { name, description, link } = Astro.props;
---

<a
  class="bg-neutral-800 py-3 px-3 rounded-xl w-full flex justify-between items-center opacity-80 hover:opacity-100 transition-opacity ease-in-out"
  href={link}
  target="_blank"
>
  <div class="flex flex-col">
    <h4 class="font-semibold">{name}</h4>
    <p class="text-neutral-400 text-sm">{description}</p>
  </div>
  <span class="icon-[tabler--arrow-right] size-8"></span>
</a>
